# Base environment shared by docker-compose files.
# Copy to .env and load an environment overlay with --env-file .env.<env>.

PROJECT_NAME=gestioncom
ENV=dev

# Networks
INTERNAL_NETWORK=internal
INTERNAL_SUBNET=10.201.0.0/24
EXTERNAL_NETWORK=external
EXTERNAL_SUBNET=10.201.1.0/24

# Reverse proxy
NGINX_PORT=80
NGINX_PORT_INTERNAL=80

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_PORT_INTERNAL=3000
FRONTEND_API_URL=http://localhost:8000
VITE_HMR_PROTOCOL=ws
VITE_HMR_HOST=localhost
VITE_HMR_CLIENT_PORT=80

# Backend API
BACKEND_API_HOST=0.0.0.0
BACKEND_API_PORT=8000
BACKEND_API_PORT_INTERNAL=8000
BACKEND_API_SECRET_KEY_FILE=./secrets/dev/backend_api_secret_key.txt
BACKEND_API_JWT_ALGORITHM=HS256
BACKEND_API_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_API_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_API_JWT_REFRESH_TOKEN_ROTATION=false
BACKEND_API_RESET_PASSWORD_REQUESTS_PER_HOUR=3
BACKEND_API_RESET_PASSWORD_CODE_LENGTH=6
BACKEND_API_RESET_PASSWORD_CODE_EXPIRE_MINUTES=15
BACKEND_API_LOG_DIR=/var/log/app
BACKEND_API_LOG_LEVEL=INFO
BACKEND_API_LOG_FILE_NAME=app.log
BACKEND_API_LOG_ROTATE_WHEN=midnight
BACKEND_API_LOG_ROTATE_INTERVAL=1
BACKEND_API_LOG_BACKUP_COUNT=7
BACKEND_API_LOG_FORMAT=txt
API_VERSION=1.0.0
DEBUG_MODE=false
ENABLE_STACK_TRACE=false

# Backend docs
DOCS_API_ENV=development
DOCS_API_HOST=0.0.0.0
DOCS_API_PORT=8010
DOCS_API_PORT_INTERNAL=8010
DOCS_API_URL=http://backend-docs:8010

# Backend tasks
TASKS_API_ENV=development
TASKS_API_HOST=0.0.0.0
TASKS_API_PORT=8020
TASKS_API_PORT_INTERNAL=8020
TASKS_API_URL=http://backend-tasks:8020

# Worker
WORKER_LOG_LEVEL=INFO
WORKER_CONCURRENCY=4
WORKER_QUEUES=default
WORKER_API_PORT_INTERNAL=8030

# MariaDB
MYSQL_HOST=mariadb
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD_FILE=./secrets/dev/mysql_root_password.txt
MYSQL_DATABASE=inventario
MYSQL_USER=inventario_user
MYSQL_PASSWORD_FILE=./secrets/dev/mysql_password.txt

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_PANEL=5540
REDIS_PASSWORD_FILE=./secrets/dev/redis_password.txt
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_TTL_RESETPASS=900
USER_SECRET_CACHE_TTL=3600
TOKEN_BLACKLIST_TTL=1800
RATE_LIMIT_WINDOW=60

# Security limits
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_LOGIN_ATTEMPTS_PER_HOUR=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER_FILE=./secrets/dev/minio_root_user.txt
MINIO_ROOT_PASSWORD_FILE=./secrets/dev/minio_root_password.txt

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
RABBITMQ_DEFAULT_USER_FILE=./secrets/dev/rabbitmq_default_user.txt
RABBITMQ_DEFAULT_PASS_FILE=./secrets/dev/rabbitmq_default_pass.txt
RABBITMQ_ERLANG_COOKIE_FILE=./secrets/dev/rabbitmq_erlang_cookie.txt

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_STORAGE=/data
MAILPIT_UI_COLOR=#2563eb

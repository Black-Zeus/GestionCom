EVENTS_SERVICE_NAME=events-orchestrator
EVENTS_ORCHESTRATOR_HOST=0.0.0.0
EVENTS_ORCHESTRATOR_PORT_INTERNAL=${EVENTS_ORCHESTRATOR_PORT_INTERNAL}
BACKEND_API_URL=http://${PROJECT_NAME}-backend-api:${BACKEND_API_PORT_INTERNAL}
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT}
REDIS_DB=${REDIS_DB}
REDIS_PASSWORD_FILE=/run/secrets/redis_password
EVENTS_STREAM_NAME=gestioncom:events:v1
EVENTS_STREAM_PREFIX=gestioncom:events:v1
EVENTS_STREAM_MAXLEN=1000
EVENTS_STREAM_IDLE_TTL_SECONDS=300
EVENTS_MAX_TARGETS_PER_EVENT=1000
EVENTS_MAX_STREAMS_PER_CONNECTION=16
EVENTS_MAX_CONNECTIONS_PER_USER=3
EVENTS_CONNECTION_TTL_SECONDS=90
EVENTS_MAX_PAYLOAD_BYTES=16384
EVENTS_READ_BLOCK_MS=25000
EVENTS_HEARTBEAT_SECONDS=20
EVENTS_DEFAULT_TTL_SECONDS=60
EVENTS_PUBLISH_TOKEN=${EVENTS_PUBLISH_TOKEN}
EVENTS_REQUIRE_PUBLISH_TOKEN=true

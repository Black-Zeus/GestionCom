# ====================================
# BACKEND DOCS - Variables Locales
# ====================================

# ====== Entorno y Configuracion ======
DOCS_API_ENV=${DOCS_API_ENV}
DOCS_API_PORT=${DOCS_API_PORT}
DOCS_API_HOST=${DOCS_API_HOST}

# ====== MinIO (Almacenamiento de documentos) ======
MINIO_HOST=http://${MINIO_HOST}:${MINIO_PORT}
MINIO_ACCESS_KEY_FILE=/run/secrets/minio_root_user
MINIO_SECRET_KEY_FILE=/run/secrets/minio_root_password
MINIO_BUCKET_TEMP=temporary
MINIO_BUCKET_BACKUPS=backups
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_INVOICES=invoices

# ====== Directorio Temporal para Archivos ======
TMP_OUTPUT=/app/tmp
